{
  "version": 1,
  "sdk_version": "0.20.0",
  "path": "/mcp",
  "auth": {
    "type": "none"
  },
  "mcp": {
    "server": {
      "name": "movixa-mcp",
      "version": "0.1.0",
      "title": "Movixa Studio MCP"
    },
    "tools": [
      {
        "name": "list_recent_inquiries",
        "title": "List recent inquiries",
        "description": "List the most recent contact form inquiries submitted to Movixa, with optional status filter.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "limit": {
              "default": 10,
              "description": "Maximum number of inquiries to return (1-50).",
              "type": "integer",
              "minimum": 1,
              "maximum": 50
            },
            "status": {
              "description": "Optional status filter.",
              "type": "string",
              "enum": [
                "new",
                "contacted",
                "in_progress",
                "completed",
                "closed"
              ]
            }
          }
        },
        "outputSchema": null
      },
      {
        "name": "get_inquiry",
        "title": "Get inquiry",
        "description": "Fetch the full details of a single Movixa contact inquiry by ID.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "id": {
              "type": "string",
              "format": "uuid",
              "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$",
              "description": "The inquiry UUID."
            }
          },
          "required": [
            "id"
          ]
        },
        "outputSchema": null
      },
      {
        "name": "update_inquiry_status",
        "title": "Update inquiry status",
        "description": "Update the workflow status of a Movixa contact inquiry.",
        "annotations": {
          "readOnlyHint": false,
          "destructiveHint": false,
          "idempotentHint": true
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "id": {
              "type": "string",
              "format": "uuid",
              "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$",
              "description": "The inquiry UUID."
            },
            "status": {
              "type": "string",
              "enum": [
                "new",
                "contacted",
                "in_progress",
                "completed",
                "closed"
              ],
              "description": "The new status."
            },
            "admin_notes": {
              "description": "Optional admin notes to save.",
              "type": "string",
              "maxLength": 4000
            }
          },
          "required": [
            "id",
            "status"
          ]
        },
        "outputSchema": null
      }
    ]
  }
}
